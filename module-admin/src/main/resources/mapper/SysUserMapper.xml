<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nan.waveform.admin.mapper.SysUserMapper">

    <select id="selectByUsername" resultType="com.nan.waveform.common.domain.entity.SysUser">
        SELECT id, username, password, real_name, create_time
        FROM sys_user
        WHERE username = #{username}
    </select>

</mapper>